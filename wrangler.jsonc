{
  "$schema": "node_modules/wrangler/config-schema.json",
  "compatibility_date": "2025-12-26",
  "name": "skland-daily-attendance1",
  "compatibility_flags": ["nodejs_als"],
  "observability": {
    "enabled": true
  },
  "kv_namespaces": [
    {
